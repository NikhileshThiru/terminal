# Copy this file to .env and fill in values. .env is gitignored.
# Phase 1 only needs the app config block. The rest unlock Phase 2+ providers.

# === LLM providers (Phase 4) ===
# Gemini: free, no credit card. https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Claude (Anthropic): paid — code stub only, NOT runtime-used.
ANTHROPIC_API_KEY=
# Groq: free, no card. https://console.groq.com/keys (key starts with gsk_)
GROQ_API_KEY=

# === Market data (Phase 2) ===
# Alpaca paper account, no SSN, no credit card. https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Finnhub free tier. https://finnhub.io/dashboard
FINNHUB_API_KEY=

# FRED. https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# SEC EDGAR has no key but requires a User-Agent in this format:
SEC_USER_AGENT=Terminal Research/0.1 (your-email@example.com)

# === Infrastructure (compose defaults work as-is for dev) ===
DATABASE_URL=postgresql+psycopg://terminal:terminal@localhost:5432/terminal
REDIS_URL=redis://localhost:6379/0

# === App config ===
LOG_LEVEL=INFO
ENVIRONMENT=development
# Comma-separated list of tickers prioritized in the UI (NOT a discovery gate)
WATCHLIST=AAPL,MSFT,NVDA,AMD,GOOGL,META,AMZN,TSLA

# === LLM routing (per-step model selection, swappable without code changes) ===
# Triage (Phase 6): a small fast model is plenty for "is this material? pass/drop".
LLM_TRIAGE_PROVIDER=gemini
LLM_TRIAGE_MODEL=gemini-2.5-flash-lite
# Thesis (Phase 4): a capable model. Groq's Llama 3.3 70B is ~5× faster than Gemini Flash
# and has higher RPM, so it handles the multi-tool loop more comfortably.
LLM_THESIS_PROVIDER=groq
LLM_THESIS_MODEL=llama-3.3-70b-versatile
